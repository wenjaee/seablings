# Supabase is optional — leave these blank to run the in-memory demo store.
# The server enables Supabase mode only when BOTH NEXT_PUBLIC_SUPABASE_URL
# and SUPABASE_SECRET_KEY are set (see lib/server/store.ts).
NEXT_PUBLIC_SUPABASE_URL=
# Client-only publishable key; currently unused by the server.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SEA_CAPTURE_BEARER_TOKEN=demo-seablings-token
NEXT_PUBLIC_DEMO_API_BASE_URL=http://localhost:3000
